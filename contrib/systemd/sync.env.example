# /etc/mnemos/sync.env — environment for mnemos-sync.service (#104)
#
# Loaded by the systemd unit via EnvironmentFile=. Every var here is read by
# scripts/sync-peers.sh on A (the SOURCE host). The passphrase VALUE lives in a
# SEPARATE env var named by MNEMOS_SYNC_PASSPHRASE_ENV — never inline here.
#
# All values below are RFC-reserved dummies (RFC 5737 IPs, example.invalid).
# Replace every one before `systemctl enable --now mnemos-sync.timer`.
#
# See docs/en/admin/ssh-sync-hardening.md for the full hardening checklist.

# ── REQUIRED (script refuses to run without these) ───────────────────────────

# Peer (TARGET) host B — the mnemos instance that imports the payload.
MNEMOS_SYNC_PEER_HOST=192.0.2.10

# Ed25519 private key on A for the rsync PUSH step (step 2/3 of sync-peers.sh).
# chmod 600, owner root. Generate per ssh-sync-hardening.md §3.
MNEMOS_SYNC_PEER_SSH_KEY=/etc/mnemos/sync-push-key

# Ed25519 private key on A for the ssh IMPORT-TRIGGER step (step 3/3).
# Separate key from the push key — each is pinned to its own command="" in
# authorized_keys on B (ssh-sync-hardening.md §2). chmod 600, owner root.
MNEMOS_SYNC_PEER_IMPORT_SSH_KEY=/etc/mnemos/sync-trigger-key

# Local dir on A where `mnemos sync export` writes the payload file.
MNEMOS_SYNC_LOCAL_EXPORT_DIR=/var/lib/mnemos-sync/export

# Dir on B where rsync delivers the payload. Must match the INCOMING_DIR
# enforced by contrib/systemd/rsync-wrapper.sh on B.
MNEMOS_SYNC_REMOTE_IMPORT_DIR=/var/lib/mnemos-sync/incoming

# Comma-separated project slugs to sync (must be in shared_projects on A).
MNEMOS_SYNC_SHARED_PROJECTS=project-alpha

# Encrypt the payload with AES-256-GCM before transfer? "true" | "false".
MNEMOS_SYNC_ENCRYPT=true

# NAME of the env var holding the passphrase on A. The passphrase VALUE is
# provisioned in the service environment (systemd LoadCredential or drop-in),
# NEVER inline in this file. sync-peers.sh reads it via ${!NAME}.
MNEMOS_SYNC_PASSPHRASE_ENV=MNEMOS_EXPORT_PASSPHRASE

# ── OPTIONAL (defaults shown) ───────────────────────────────────────────────

# SSH user on B (default: mnemos-sync). Must match the dedicated user created
# per ssh-sync-hardening.md §1.
# MNEMOS_SYNC_PEER_USER=mnemos-sync

# Dry-run — "1" logs the commands to stderr and exits 0 before any real
# execution (no export, no rsync, no ssh). Use for first-time validation.
# MNEMOS_SYNC_DRY_RUN=0

# Path to A's mnemos config.yaml (default: mnemos auto-discovery).
# MNEMOS_SYNC_SOURCE_CONFIG=

# Basename of the payload file on B (default: mnemos-sync-<UTC-timestamp>.json).
# MNEMOS_SYNC_REMOTE_FILE=

# Path to the mnemos CLI on A (default: auto-discover via PATH or .venv).
# MNEMOS_SYNC_MNEMOS_BIN=

# ── PASSPHRASE VALUE (separate from the NAME above) ──────────────────────────
# Provision this via `systemctl edit mnemos-sync.service` (a drop-in) or via
# systemd LoadCredential — NOT in this file, which may be world-readable.
# The NAME in MNEMOS_SYNC_PASSPHRASE_ENV must point at this var.
#
# Example drop-in (/etc/systemd/system/mnemos-sync.service.d/passphrase.conf):
#   [Service]
#   Environment="MNEMOS_EXPORT_PASSPHRASE=<your-secret-here>"
#
# Or LoadCredential (preferred — file-based, not in `systemctl show`):
#   [Service]
#   LoadCredential=mnemos-export-passphrase:/etc/mnemos/passphrase
#   Environment="MNEMOS_EXPORT_PASSPHRASE_FILE=%d/mnemos-export-passphrase"
# (then sync-peers.sh reads $MNEMOS_EXPORT_PASSPHRASE — adapt if you use the
#  _FILE variant; mnemos sync export currently reads the env var directly.)